{
  "caseIgnores": {
    "IgnoredCase": {
      "textEnd": ":",
      "textStart": "[^"
    }
  },
  "preset": "default",
  "rules": {
    "adjustedFullwidthPunctuation": "‘’",
    "spaceOutsideHalfQuote": false,
    "unifiedPunctuation": {
      "default": false,
      "「": [
        "「",
        "“"
      ],
      "」": [
        "」",
        "”"
      ]
    }
  }
}
